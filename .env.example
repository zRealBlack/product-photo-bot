# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Google Gemini (Image Generation) ───
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google Custom Search API (Product Image Search) ───
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_custom_search_engine_id_here

# ─── Google Drive API (Service Account) ───
# Local dev: path to the .json file
# Railway: paste the entire JSON content as the value
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=service_account.json
